desktop-notifications = false 

font-family = "JetBrainsMono Nerd Font Mono"
# font-family = "MesloLGL Nerd Font Mono"
font-feature = -calt
font-size = 11

resize-overlay = never
theme = Afterglow

window-decoration = none
maximize = true
gtk-titlebar-hide-when-maximized = true
gtk-wide-tabs = false
copy-on-select = true

keybind = ctrl+a>h=new_split:down
keybind = ctrl+a>v=new_split:right
keybind = ctrl+a>t=new_tab
keybind = ctrl+a>x=close_surface
#keybind = ctrl+shift+d=new_split:down
#keybind = ctrl+shift+r=new_split:right

keybind = ctrl+shift+k=goto_split:up
keybind = ctrl+shift+j=goto_split:down
keybind = ctrl+shift+l=goto_split:right
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+up=goto_split:up
keybind = ctrl+shift+down=goto_split:down
keybind = ctrl+shift+right=goto_split:right
keybind = ctrl+shift+left=goto_split:left

keybind = ctrl+shift+alt+plus=equalize_splits
keybind = ctrl+shift+alt+k=resize_split:up,10
keybind = ctrl+shift+alt+j=resize_split:down,10
keybind = ctrl+shift+alt+l=resize_split:right,10
keybind = ctrl+shift+alt+h=resize_split:left,10
keybind = ctrl+shift+alt+up=resize_split:up,10
keybind = ctrl+shift+alt+down=resize_split:down,10
keybind = ctrl+shift+alt+right=resize_split:right,10
keybind = ctrl+shift+alt+left=resize_split:left,10

keybind = ctrl+a>left_bracket=goto_split:previous
keybind = ctrl+a>right_bracket=goto_split:next

keybind = ctrl+a>z=toggle_split_zoom

window-padding-x = 3
window-padding-y = 10

keybind = ctrl+g=scroll_to_bottom
keybind = ctrl+shift+[=scroll_page_up
keybind = ctrl+shift+]=scroll_page_down
# keybind = ctrl+shift+{=jump_to_prompt:-1
# keybind = ctrl+shift+}=jump_to_prompt:1

scrollback-limit = 10000000
gtk-single-instance = true
